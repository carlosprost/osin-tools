{
  "productName": "SODIIC",
  "version": "0.1.0",
  "identifier": "com.sodiic.investigacion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/tor"],
    "resources": ["resources/tor/*"]
  },
  "app": {
    "windows": [
      {
        "title": "SODIIC - Sistema de Organización de Investigaciones e Inteligencia Criminal",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  }
}
